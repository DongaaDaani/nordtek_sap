# SAP API credentials (set these in Vercel Dashboard → Settings → Environment Variables)
SAP_BASE_URL=https://interface-v2.nordtek.hu/v1
SAP_CLIENT_ID=your_client_id
SAP_API_KEY=your_api_key

# Optional: Redis URL for MCP SSE session persistence (needed for Claude Desktop SSE mode)
# Get one free at upstash.com
REDIS_URL=

# App URL (set automatically by Vercel, or set manually for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
